# ──────────────────────────────────────────────
# Behavio — Environment Variables
# Copy this file to .env.local and fill in your keys.
# ──────────────────────────────────────────────

# ── Required ──────────────────────────────────
# Anthropic API key — powers all AI workflows (plan generation, daily tasks, coaching, etc.)
ANTHROPIC_API_KEY=

# ── Optional: Supabase (auth & data persistence) ──
# Without these the app runs in local-only mode (localStorage, no login)
#
# Pay-without-email-account: Authentication → Providers → enable Anonymous.
# The app signs users in anonymously on load (except /signup, /auth, /forgot-password),
# then Stripe Checkout uses that user id — no email/password required for the main flow.
#
# Optional email accounts: enable Email provider; turn OFF “Confirm email” for instant access.
# Redirect URLs: http://localhost:3000/auth/callback and https://YOUR_DOMAIN/auth/callback
#
# Stripe webhooks MUST update Supabase with the service role (set this key on the server):
NEXT_PUBLIC_SUPABASE_URL=
# Use the dashboard publishable key (any of these names) or the legacy anon JWT:
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # required for /api/webhooks/stripe to set is_premium (RLS-safe)

# ── Optional: Firecrawl (event discovery) ──
# Without this, plan generation skips event fetching
FIRECRAWL_API_KEY=

# ── Optional: SerpAPI (Google Events in Explore / home) ──
# Also accepted: SERP_API_KEY or SERAPI_KEY. Restart `npm run dev` after changing.
SERPAPI_KEY=

# ── Optional: Stripe (payments) ──
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ANNUAL=
# Optional — when set, paywall shows monthly + annual (create a monthly recurring price in Stripe)
STRIPE_PRICE_PRO_MONTHLY=
# Subscription trial length in days (default 3). Set 0 for no trial in Checkout.
STRIPE_TRIAL_DAYS=3

# ── Optional: Google Calendar ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ── Optional: Cron / Push Notifications ──
CRON_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# ── Optional: App URL (used by cron jobs) ──
NEXT_PUBLIC_URL=http://localhost:3000

# ── Optional: Ad Pixels (for paid-traffic optimization) ──
# Each pixel is silently skipped if its ID is empty. Restart the dev server
# after editing. After purchase the app fires Purchase / InitiateCheckout / Lead /
# ViewContent to whichever pixels are loaded — this is what trains the ad
# networks. UTM/click-ID params (utm_source, fbclid, ttclid, gclid, …) are
# captured on first page load and forwarded to Stripe checkout metadata for
# attribution.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=
